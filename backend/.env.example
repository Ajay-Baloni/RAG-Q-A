# ---- Server ----
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGIN=http://localhost:5173

# ---- Database (Neon PostgreSQL + pgvector) ----
# connect_timeout gives Neon's serverless compute time to wake from auto-suspend
# (free tier scales to zero when idle) so the first request doesn't fail with P1001.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require&connect_timeout=15

# ---- Auth ----
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-long-random-string
# 30 days "remember me"
JWT_EXPIRES_IN=30d

# ---- Google Gemini (LLM + embeddings) ----
GEMINI_API_KEY=your-gemini-key

# ---- Groq (fallback LLM) ----
GROQ_API_KEY=your-groq-key

TAVILY_API_KEY=

# ---- Cloudinary (PDF storage) ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- Email (password reset, via Resend) ----
# Optional: if RESEND_API_KEY is unset, reset links are logged to the server console instead of emailed.
RESEND_API_KEY=your-resend-key
# In test mode (no verified domain) Resend sends from onboarding@resend.dev to your own account email only.
EMAIL_FROM=Lexica <onboarding@resend.dev>
